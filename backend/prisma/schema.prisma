generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  address   String
  role      Role

  stores    Store[]
  ratings   Rating[]

  createdAt DateTime @default(now())
}

model Store {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  address   String

  ownerId   Int
  owner     User     @relation(fields: [ownerId], references: [id])

  ratings   Rating[]

  createdAt DateTime @default(now())
}

model Rating {
  id        Int      @id @default(autoincrement())
  rating    Int
  review    String

  userId    Int
  storeId   Int

  user      User     @relation(fields: [userId], references: [id])
  store     Store    @relation(fields: [storeId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, storeId])
}

enum Role {
  ADMIN
  USER
  OWNER
}